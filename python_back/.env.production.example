# NMED Python analysis API production environment
# Nusxa oling: cp .env.production.example .env
# Python backend config.py aynan python_back/.env faylini o'qiydi.

OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY
OPENAI_MODEL=gpt-4o

# Agar ishlatilsa to'ldiring, aks holda bo'sh qoldirish mumkin.
ANTHROPIC_API_KEY=

DATABASE_URL=postgresql://nmed_user:CHANGE_ME_DB_PASSWORD@127.0.0.1:5432/med_helper_data

# .NET backenddagi Jwt__Key bilan AYNAN bir xil bo'lishi shart.
JWT_SECRET=CHANGE_ME_64_PLUS_RANDOM_CHARS

# Python API frontenddan emas, asosan .NET proxydan chaqiriladi.
ALLOWED_ORIGINS=https://nmed.uz,https://api.nmed.uz
