# NMED .NET API production environment
# Nusxa oling: cp .env.production.example .env.production
# Keyin CHANGE_ME qiymatlarini real production secretlar bilan almashtiring.

ASPNETCORE_ENVIRONMENT=Production

# Nginx reverse proxy api.nmed.uz -> http://127.0.0.1:5000 ga yo'naltiradi.
Kestrel__BindAddress=127.0.0.1
Kestrel__HttpPort=5000
Kestrel__EnableHttpsEndpoint=false
Swagger__Enabled=false

ConnectionStrings__DefaultConnection=Host=127.0.0.1;Port=5432;Database=med_helper_data;Username=nmed_user;Password=CHANGE_ME_DB_PASSWORD

Jwt__Key=CHANGE_ME_64_PLUS_RANDOM_CHARS
Jwt__Issuer=NMEDAnalyzerApi
Jwt__Audience=NMEDAnalyzerApiUsers

Encryption__AesKey=CHANGE_ME_BASE64_32_BYTE_AES_KEY
OpenAI__ApiKey=CHANGE_ME_OPENAI_API_KEY
ReCaptcha__SecretKey=CHANGE_ME_RECAPTCHA_SECRET

PythonApi__BaseUrl=http://127.0.0.1:8000
App__PublicUrl=https://nmed.uz

# Vergul bilan ajratilgan CORS originlar.
Cors__AllowedOrigins=https://nmed.uz,https://www.nmed.uz

LiveKit__Url=wss://CHANGE_ME.livekit.cloud
LiveKit__ApiKey=CHANGE_ME_LIVEKIT_API_KEY
LiveKit__ApiSecret=CHANGE_ME_LIVEKIT_API_SECRET

Smtp__Host=smtp.gmail.com
Smtp__Port=587
Smtp__Username=CHANGE_ME_SMTP_USERNAME
Smtp__Password=CHANGE_ME_SMTP_PASSWORD
Smtp__FromName=NMED

Eskiz__Email=CHANGE_ME_ESKIZ_EMAIL
Eskiz__Password=CHANGE_ME_ESKIZ_PASSWORD
