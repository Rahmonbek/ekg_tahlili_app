{
  "agent": "nmed-system-architect",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1"
  },
  "permissions": {
    "mode": "acceptEdits",
    "allow": [
      "Bash(grep *)",
      "Bash(dotnet ef *)",
      "Bash(dotnet build *)",
      "Bash(dotnet run *)",
      "Bash(npm start *)",
      "Bash(netstat *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(git diff *)",
      "Bash(echo *)",
      "Read(*)",
      "Glob(*)",
      "Grep(*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(drop database *)",
      "Bash(mkfs *)"
    ]
  },
  "teammateMode": "in-process",
  "effort": "high"
}